---
export interface Props {
  image: string;
  slitHeights?: number[];
  gapHeights?: number[];
  parallaxDirection?: 'diagonal-right' | 'diagonal-left' | 'horizontal';
  className?: string;
  'data-multi-speed'?: string;
}

const {
  image,
  slitHeights = [110, 80, 140, 90, 120],
  gapHeights  = [70, 80, 65, 75],
  parallaxDirection = 'diagonal-right',
  className = '',
  ...rest
} = Astro.props;

// Build the alternating segment list that describes the full vertical stack:
//   [top void] → slit → gap → slit → gap → … → slit → [bottom void]
// Gap segments get a void-colored div; slit segments get a transparent div.
// The image layer behind shows only through the transparent (slit) segments.

type Segment = { type: 'slit' | 'gap'; height: number };
const segments: Segment[] = [];

const edgePad = 400; // generous top/bottom void bands

segments.push({ type: 'gap', height: edgePad });

for (let i = 0; i < slitHeights.length; i++) {
  segments.push({ type: 'slit', height: slitHeights[i] });
  if (i < slitHeights.length - 1) {
    segments.push({ type: 'gap', height: gapHeights[i] ?? 70 });
  }
}

segments.push({ type: 'gap', height: edgePad });

const totalHeight = segments.reduce((sum, s) => sum + s.height, 0);
---

<div
  class={`louver-field ${className}`}
  data-parallax-direction={parallaxDirection}
  style={`height: ${totalHeight}px;`}
  {...rest}
>
  <!-- Image layer — oversized to allow parallax travel without revealing edges -->
  <div class="louver-image-layer">
    <img src={image} alt="" loading="lazy" aria-hidden="true" />
  </div>

  <!-- Mask layer — alternating void bands and transparent slits -->
  <div class="louver-mask" aria-hidden="true">
    {segments.map(seg => (
      <div
        class={`louver-segment louver-${seg.type}`}
        style={`height: ${seg.height}px;`}
      />
    ))}
  </div>
</div>

<style lang="scss">
  @import '../styles/variables';

  .louver-field {
    position: relative;
    overflow: hidden;
    width: 100%;
    // No margin — placement/spacing is controlled by the page layout
  }

  // ── Image layer ────────────────────────────────────────────────────────────
  // Oversized 140% so parallax can travel 8-15% in any direction
  // without ever showing a blank edge.

  .louver-image-layer {
    position: absolute;
    top: -20%;
    left: -20%;
    width: 140%;
    height: 140%;
    z-index: 1;
  }

  .louver-image-layer img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(75%) contrast(1.15) brightness(0.55);
  }

  // ── Mask layer ─────────────────────────────────────────────────────────────
  // Stacks the segment divs in a column. Void bands hide the image;
  // transparent bands reveal it through the layer below.

  .louver-mask {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    display: flex;
    flex-direction: column;
  }

  .louver-segment {
    flex-shrink: 0;
    width: 100%;
  }

  .louver-gap {
    background: $void-primary;
  }

  // Slits reveal the image. The inset shadow adds physical depth —
  // the sense of peering through thick material.
  .louver-slit {
    background: transparent;
    box-shadow:
      inset 0 8px 30px rgba(0, 0, 0, 0.9),
      inset 0 -8px 30px rgba(0, 0, 0, 0.9);
  }

  // ── Reduced motion ─────────────────────────────────────────────────────────
  @media (prefers-reduced-motion: reduce) {
    .louver-image-layer {
      top: -10%;
      left: -10%;
      width: 120%;
      height: 120%;
    }
  }
</style>
