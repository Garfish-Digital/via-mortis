---
import GlitchTransition from './GlitchTransition.astro';
import DisplacementMap from './displacementMap.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  date?: string;
  category?: string;
  href?: string;
  className?: string;
}

const {
  title,
  description,
  image,
  date,
  category = 'Attraction',
  href = '#',
  className = '',
  ...rest
} = Astro.props;
---

<a href={href} class={`post-card-link ${className}`} {...rest}>
  <article class="post-card" data-ghost-reveal>
    <DisplacementMap intensity={5} frequency={0.015} className="card-wrapper">
      <div class="card-inner">
        {image && (
          <div class="card-image">
            <img src={image} alt={title} loading="lazy" />
            <div class="image-overlay"></div>
          </div>
        )}

        <div class="card-content">
          <div class="card-meta">
            <span class="category">{category}</span>
            {date && <span class="date">{date}</span>}
          </div>

          <h3 class="card-title">{title}</h3>

          <p class="card-description">{description}</p>
        </div>
      </div>
    </DisplacementMap>
  </article>
</a>

<style lang="scss">
  @import '../styles/variables';

  .post-card-link {
    display: block;
    height: 100%;
    text-decoration: none;
    cursor: inherit;
  }

  .post-card {
    position: relative;
    height: 100%;
    transition: transform 0.5s ease-in-out;
    cursor: inherit;
  }

  .card-wrapper {
    height: 100%;
    display: block;
    cursor: inherit;
  }

  .card-inner {
    position: relative;
    height: 100%;
    background: linear-gradient(
      135deg,
      rgba($void-elevated, 0.9) 0%,
      rgba($void-deep-field, 0.8) 50%,
      rgba($void-elevated, 0.9) 100%
    );
    border: 1px solid rgba($cold-decayed, 0.2);
    overflow: hidden;
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    transition: all 0.5s ease;
    cursor: inherit;
  }

  .card-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba($cold-bruised, 0.06) 0%,
      transparent 50%,
      rgba($cold-decayed, 0.03) 100%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: 1;
  }

  .card-inner:hover {
    border-color: rgba($wrong-bruised-purple, 0.3);
    box-shadow: 0 8px 40px rgba($wrong-bruised-purple, 0.08);
  }

  .card-inner:hover::before {
    opacity: 1;
  }

  .card-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease, filter 0.4s ease;
    filter: grayscale(30%) contrast(1.1);
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to top,
      rgba($void-primary, 0.7) 0%,
      transparent 60%
    );
    opacity: 0.8;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .card-inner:hover .image-overlay {
    opacity: 0.5;
  }

  .card-inner:hover .card-image img {
    transform: scale(1.05);
    filter: grayscale(0%) contrast(1.2);
  }

  .card-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 2;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .category {
    color: $cold-bruised;
    font-family: $font-sans;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
  }

  .date {
    color: $cold-decayed;
    font-family: $font-mono;
    font-size: 0.75rem;
  }

  .title-wrapper {
    margin-bottom: 1rem;
  }

  .card-title {
    margin: 0;
    font-size: 1.5rem;
    font-family: $font-display;
    line-height: 1.3;
    color: $cold-biological;
    transition: color 0.3s ease;
  }

  .card-inner:hover .card-title {
    color: $cold-pale-fog;
    text-shadow: 0 0 20px rgba($cold-pale-fog, 0.15);
  }

  .card-description {
    color: $cold-biological;
    line-height: 1.6;
    opacity: 0.8;
    flex: 1;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .card-content {
      padding: 1rem;
    }

    .card-title {
      font-size: 1.25rem;
    }

    .card-description {
      font-size: 0.9rem;
    }
  }

  /* Accessibility */
  @media (prefers-reduced-motion: reduce) {
    .card-inner,
    .card-image img {
      transition: none;
    }

    .card-inner:hover .card-image img {
      transform: none;
    }
  }

  /* Focus styles */
  .post-card-link:focus {
    outline: 2px solid $cold-pale-fog;
    outline-offset: 2px;
  }
</style>
