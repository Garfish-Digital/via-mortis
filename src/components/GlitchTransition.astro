---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
  trigger?: 'hover' | 'scroll' | 'auto';
  className?: string;
}

const {
  intensity = 'medium',
  trigger = 'auto',
  className = '',
  ...rest
} = Astro.props;
---

<div
  class={`melt-container ${className}`}
  data-melt-trigger={trigger}
  data-melt-intensity={intensity}
  {...rest}
>
  <slot />
</div>

<style lang="scss">
  @import '../styles/variables';

  .melt-container {
    position: relative;
    display: block;
    transition: filter 0.6s ease-in-out, transform 0.6s ease-in-out;
  }

  .melt-container :global(h2),
  .melt-container :global(h3) {
    font-family: $font-display;
    color: $cold-pale-fog;
    text-shadow:
      0 0 8px rgba($wrong-bruised-purple, 0.3),
      0 0 16px rgba($cold-pale-fog, 0.15);
  }

  .melt-container :global(p) {
    font-family: $font-display;
  }
</style>

<script>
  // ── Shared SVG filter (injected once) ──────────────────────────────────────

  const FILTER_ID = 'melt-displacement';

  function ensureMeltFilter(): SVGFEDisplacementMapElement | null {
    if (document.getElementById(FILTER_ID)) {
      return document.querySelector(`#${FILTER_ID} feDisplacementMap`);
    }

    const ns = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(ns, 'svg');
    svg.setAttribute('width', '0');
    svg.setAttribute('height', '0');
    svg.style.position = 'absolute';
    svg.style.pointerEvents = 'none';

    const filter = document.createElementNS(ns, 'filter');
    filter.setAttribute('id', FILTER_ID);
    filter.setAttribute('x', '-10%');
    filter.setAttribute('y', '-10%');
    filter.setAttribute('width', '120%');
    filter.setAttribute('height', '120%');

    const turbulence = document.createElementNS(ns, 'feTurbulence');
    turbulence.setAttribute('type', 'turbulence');
    turbulence.setAttribute('baseFrequency', '0.015 0.025');
    turbulence.setAttribute('numOctaves', '3');
    turbulence.setAttribute('seed', '4');
    turbulence.setAttribute('result', 'warp');

    const displacement = document.createElementNS(ns, 'feDisplacementMap');
    displacement.setAttribute('in', 'SourceGraphic');
    displacement.setAttribute('in2', 'warp');
    displacement.setAttribute('scale', '0');
    displacement.setAttribute('xChannelSelector', 'R');
    displacement.setAttribute('yChannelSelector', 'G');

    filter.appendChild(turbulence);
    filter.appendChild(displacement);
    svg.appendChild(filter);
    document.body.appendChild(svg);

    return displacement;
  }

  // ── Per-instance animation ─────────────────────────────────────────────────

  const INTENSITY_SCALE = { low: 8, medium: 15, high: 25 };
  const MELT_IN_DURATION = 600;
  const MELT_OUT_DURATION = 600;

  const activeAnimations = new WeakMap<HTMLElement, number>();
  let activeMeltCount = 0;
  let sharedDisplacement: SVGFEDisplacementMapElement | null = null;

  function getOrCreateFilter(el: HTMLElement): {
    filterId: string;
    displacement: SVGFEDisplacementMapElement;
  } {
    const existing = el.dataset.meltFilterId;
    if (existing) {
      const disp = document.querySelector(
        `#${existing} feDisplacementMap`
      ) as SVGFEDisplacementMapElement | null;
      if (disp) return { filterId: existing, displacement: disp };
    }

    if (activeMeltCount === 0 && sharedDisplacement) {
      el.dataset.meltFilterId = FILTER_ID;
      return { filterId: FILTER_ID, displacement: sharedDisplacement };
    }

    // Clone the filter for concurrent use
    const id = `${FILTER_ID}-${Date.now()}-${Math.random().toString(36).slice(2, 6)}`;
    const originalFilter = document.getElementById(FILTER_ID);
    if (!originalFilter) {
      return { filterId: FILTER_ID, displacement: sharedDisplacement! };
    }

    const svg = originalFilter.closest('svg')!;
    const clone = originalFilter.cloneNode(true) as SVGFilterElement;
    clone.setAttribute('id', id);
    svg.appendChild(clone);

    const disp = clone.querySelector('feDisplacementMap') as SVGFEDisplacementMapElement;
    el.dataset.meltFilterId = id;
    return { filterId: id, displacement: disp };
  }

  function cleanupFilter(el: HTMLElement): void {
    const id = el.dataset.meltFilterId;
    if (id && id !== FILTER_ID) {
      document.getElementById(id)?.remove();
    }
    delete el.dataset.meltFilterId;
  }

  function animateScale(
    displacement: SVGFEDisplacementMapElement,
    from: number,
    to: number,
    duration: number,
    onDone?: () => void
  ): number {
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const t = Math.min(elapsed / duration, 1);
      const eased = t < 0.5
        ? 4 * t * t * t
        : 1 - Math.pow(-2 * t + 2, 3) / 2;

      const current = from + (to - from) * eased;
      displacement.setAttribute('scale', String(current));

      if (t < 1) {
        requestAnimationFrame(tick);
      } else {
        onDone?.();
      }
    }

    return requestAnimationFrame(tick);
  }

  function meltIn(el: HTMLElement): void {
    const prev = activeAnimations.get(el);
    if (prev) cancelAnimationFrame(prev);

    const intensity = el.dataset.meltIntensity as keyof typeof INTENSITY_SCALE || 'medium';
    const peak = INTENSITY_SCALE[intensity] || INTENSITY_SCALE.medium;

    const { filterId, displacement } = getOrCreateFilter(el);
    activeMeltCount++;

    el.style.filter = `url(#${filterId}) brightness(0.93) blur(0.6px)`;
    el.style.transform = 'translateY(1.5px)';

    const currentScale = parseFloat(displacement.getAttribute('scale') || '0');
    const frameId = animateScale(displacement, currentScale, peak, MELT_IN_DURATION);
    activeAnimations.set(el, frameId);
  }

  function meltOut(el: HTMLElement): void {
    const prev = activeAnimations.get(el);
    if (prev) cancelAnimationFrame(prev);

    const filterId = el.dataset.meltFilterId;
    if (!filterId) return;
    const displacement = document.querySelector(
      `#${filterId} feDisplacementMap`
    ) as SVGFEDisplacementMapElement | null;
    if (!displacement) return;

    const currentScale = parseFloat(displacement.getAttribute('scale') || '0');

    // Keep the SVG filter applied during the out-animation so displacement
    // visibly eases back to 0. CSS filter transitions brightness/blur back
    // via the 0.8s transition on the element.
    el.style.filter = `url(#${filterId})`;
    el.style.transform = '';

    const frameId = animateScale(displacement, currentScale, 0, MELT_OUT_DURATION, () => {
      // Only now remove the filter entirely
      el.style.filter = '';
      activeMeltCount = Math.max(0, activeMeltCount - 1);
      cleanupFilter(el);
      activeAnimations.delete(el);
    });
    activeAnimations.set(el, frameId);
  }

  function meltOnce(el: HTMLElement): void {
    const prev = activeAnimations.get(el);
    if (prev) cancelAnimationFrame(prev);

    const intensity = el.dataset.meltIntensity as keyof typeof INTENSITY_SCALE || 'medium';
    const peak = INTENSITY_SCALE[intensity] || INTENSITY_SCALE.medium;

    const { filterId, displacement } = getOrCreateFilter(el);
    activeMeltCount++;

    el.style.filter = `url(#${filterId}) brightness(0.93) blur(0.4px)`;
    el.style.transform = 'translateY(1.5px)';

    const frameId = animateScale(displacement, 0, peak, MELT_IN_DURATION, () => {
      // Hold briefly at peak, then melt back out
      setTimeout(() => {
        // Keep filter URL during out-animation
        el.style.filter = `url(#${filterId})`;
        el.style.transform = '';

        animateScale(displacement, peak, 0, MELT_OUT_DURATION, () => {
          el.style.filter = '';
          activeMeltCount = Math.max(0, activeMeltCount - 1);
          cleanupFilter(el);
          activeAnimations.delete(el);
        });
      }, 200);
    });
    activeAnimations.set(el, frameId);
  }

  // ── Setup ──────────────────────────────────────────────────────────────────

  function initMeltContainers(): void {
    sharedDisplacement = ensureMeltFilter();

    document.querySelectorAll<HTMLElement>('.melt-container').forEach(container => {
      if (container.closest('[data-ghost-clone]')) return;
      if (container.dataset.meltInit) return;
      container.dataset.meltInit = 'true';

      const trigger = container.dataset.meltTrigger || 'auto';

      if (trigger === 'hover') {
        container.addEventListener('mouseenter', () => meltIn(container));
        container.addEventListener('mouseleave', () => meltOut(container));
      } else if (trigger === 'scroll') {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                meltOnce(container);
                observer.disconnect();
              }
            });
          },
          { threshold: 0.1 }
        );
        observer.observe(container);
      } else if (trigger === 'auto') {
        setTimeout(() => meltOnce(container), 400);
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initMeltContainers);
  document.addEventListener('astro:page-load', initMeltContainers);
</script>
