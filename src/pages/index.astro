---
import BaseLayout from "../layouts/BaseLayout.astro";
import GlitchTransition from "../components/GlitchTransition.astro";
import PostCard from "../components/PostCard.astro";
import LouverStrip from "../components/LouverStrip.astro";
---

<BaseLayout title="Via Mortis - Macabre Tourism & Haunted Attractions">
  <!-- Hero Section -->
  <section class="hero fullscreen" data-ghost-hero>
    <div class="hero-content ghost-real-content" style="opacity:0">
      <div class="hero-title-wrapper">
        <h1>Via Mortis</h1>
      </div>

      <div class="hero-subtitle">
          <p>Where the curious come to rest</p>
      </div>

    </div>

    <div class="hero-fog"></div>
  </section>

  <!-- Louver 1 — After Hero -->
  <LouverStrip
    image="/assets/images/parallax-strips/face-1.webp"
    slitHeights={[130, 90, 160, 100, 140]}
    gapHeights={[80, 90, 70, 85]}
    parallaxDirection="diagonal-right"
    className="louver-1"
  />

  <!-- Haunted attractions Section -->
  <section class="section tap-list" data-ghost-reveal>
    <div class="container ghost-real-content">
      <h2>Haunted Attractions</h2>

      <div class="attractions-grid">
        <PostCard
          data-destructible
          title="The Screaming Cellar"
          description="They sealed the cellar in 1903 after the last surveyor refused to describe what he'd found. We unsealed it. The stairs go further down than the building plans suggest."
          image="/assets/images/attractions/dungeon-stairwell.webp"
          date="Est. 1887"
          category="Subterranean Tour"
        />

        <PostCard
          data-destructible
          title="Mirror Maze of Souls"
          description="The mirrors were recovered from a condemned psychiatric facility in Vienna. Staff reported that reflections would continue moving after patients had left the room."
          image="/assets/images/attractions/mirror.webp"
          date="Est. 1923"
          category="Perceptual Horror"
        />

        <PostCard
          data-destructible
          title="Extreme Hauntings"
          description="Our most restricted experience. Requires a signed waiver and a companion. We have never disclosed what happens inside. The 40% completion rate speaks for itself."
          image="/assets/images/attractions/house-stairwell.webp"
          date="By appointment"
          category="Extreme Experience"
        />

        <PostCard
          data-destructible
          title="Surgeon's Theatre"
          description="Dr. Ashworth's operating theatre has been preserved exactly as it was found — instruments laid out, table stained, the overhead lamp still warm. He was never apprehended."
          image="/assets/images/attractions/medical.webp"
          date="Est. 1902"
          category="Medical Horror"
        />

        <PostCard
          data-destructible
          title="Famous Crimes"
          description="Walk the reconstructed scenes of crimes that were never solved. Every detail is forensically accurate. Some visitors report noticing details that have since vanished."
          image="/assets/images/attractions/crime-scene.webp"
          date="Rotating exhibits"
          category="True Crime"
        />

        <PostCard
          data-destructible
          title="The Midnight Séance"
          description="A genuine medium. A genuine circle. We make no claims about what will or will not respond. Sessions are recorded. You will receive your recording within 48 hours."
          image="/assets/images/attractions/ouija.webp"
          date="Nightly, midnight"
          category="Paranormal"
        />
      </div>
    </div>
  </section>

  <!-- Louver 2 — After Attractions -->
  <LouverStrip
    image="/assets/images/parallax-strips/hall.webp"
    slitHeights={[90, 60, 130, 50, 115, 80]}
    gapHeights={[70, 80, 65, 85, 75]}
    parallaxDirection="diagonal-left"
    className="louver-2"
    data-multi-speed="true"
  />

  <!-- Our Story Section -->
  <section class="section our-story" data-ghost-reveal>
    <div class="container ghost-real-content">
      <div class="story-content">
        <div>
          <h2>What Remains</h2>

          <div class="story-paragraphs">
            <p data-destructible>
              The building at Glendower Avenue was condemned in 1959. It was
              not purchased. It was inherited — by an organization that does not
              appear in any public registry. Renovation began in 1987 and has
              never officially ended.
            </p>

            <p data-destructible>
              We do not employ actors. We do not use props. Every artifact in
              our collection is authentic, acquired through channels we are not
              at liberty to discuss. The experiences you will have here are not
              simulated.
            </p>

            <p data-destructible>
              Previous visitors have reported lingering effects — a persistent
              feeling of being observed, difficulty sleeping in dark rooms, an
              aversion to mirrors. These reports have not been investigated. We
              advise you to visit during daylight hours, though we are only open
              after dark.
            </p>
          </div>
          </div>
        <div class="story-image" data-destructible>
          <img src="/assets/images/about/building.webp" alt="219 Nightmare Lane" />
          <div class="story-image-overlay"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Louver 3 — After Our Story -->
  <LouverStrip
    image="/assets/images/parallax-strips/face-2.webp"
    slitHeights={[170, 110, 130, 150]}
    gapHeights={[90, 80, 85]}
    parallaxDirection="horizontal"
    className="louver-3"
  />

  <!-- Documented Observations Section -->
  <section class="section observations-section" data-ghost-reveal>
    <div class="container ghost-real-content">
      <h2>Documented Observations</h2>

      <div class="attractions-grid">
        <PostCard
          data-destructible
          title="The Lower Corridor"
          description='"The guide told us not to look at the end of the corridor on the lower level. I looked. I have not been able to describe it accurately to anyone."'
          image="/assets/images/tours/tour-1.webp"
          date="S. Harrow, Edinburgh · 14 Nov 2021"
          category="Field Report"
        />

        <PostCard
          data-destructible
          title="The Mirror Room"
          description='"My husband and I disagree about what we saw in the mirror room. We have not discussed it since."'
          image="/assets/images/tours/tour-2.webp"
          date="L. Vane, Cardiff · 3 Feb 2022"
          category="Field Report"
        />

        <PostCard
          data-destructible
          title="Seven Figures"
          description='"The photograph I took on the stairwell shows seven figures. There were four of us."'
          image="/assets/images/tours/tour-3.webp"
          date="R. Castellano, Turin · 2 Oct 2022"
          category="Field Report"
        />

        <PostCard
          data-destructible
          title="Emergency Protocol"
          description='"I work in emergency medicine. I have seen things. This was different."'
          image="/assets/images/tours/tour-4.webp"
          date="M. Oduya, Lagos · 19 Aug 2023"
          category="Field Report"
        />
      </div>
    </div>
  </section>

  <!-- Louver 5 — After Documented Observations -->
  <LouverStrip
    image="/assets/images/parallax-strips/scalpel.webp"
    slitHeights={[130, 90, 160, 100, 140]}
    gapHeights={[80, 90, 75, 85]}
    parallaxDirection="diagonal-left"
    className="louver-5"
  />

  <!-- Events Section -->
  <section class="section events-section" data-ghost-reveal>
    <div class="container ghost-real-content">
      <h2>Upcoming Horrors</h2>

      <div class="events-layout">
        <div class="events-calendar">
          <div class="event-card" data-destructible>
            <div class="event-date">
              <span class="day">27</span>
              <span class="month">Aug</span>
            </div>
            <div class="event-details">
              <h3>Hungry Ghost Festival</h3>
              <p>
                The veil thins on the seventh lunar month. We open the building
                to any who wish to enter — and to any who cannot leave. Incense
                will burn throughout. The doors will remain unlocked.
              </p>
              <span class="event-time">Dusk — Sunrise</span>
            </div>
            <div class="event-cta">
              <button class="event-button">Enter</button>
            </div>
          </div>

          <div class="event-card" data-destructible>
            <div class="event-date">
              <span class="day">13</span>
              <span class="month">Oct</span>
            </div>
            <div class="event-details">
              <h3>Midnight Massacre Tour</h3>
              <p>
                Our most terrifying attraction after hours. Limited to 13
                guests. No photography. No refunds.
              </p>
              <span class="event-time">11:30 PM — 2:00 AM</span>
            </div>
            <div class="event-cta">
              <button class="event-button">Book Now</button
              >
            </div>
          </div>

          <div class="event-card" data-destructible>
            <div class="event-date">
              <span class="day">31</span>
              <span class="month">Oct</span>
            </div>
            <div class="event-details">
              <h3>All Hallows Descent</h3>
              <p>
                The one night per year we remove all safety protocols. Costumes
                mandatory. Emergency exits will be clearly marked. We recommend
                memorising their locations.
              </p>
              <span class="event-time">6:00 PM — 3:00 AM</span>
            </div>
            <div class="event-cta">
              <button class="event-button">Reserve</button
              >
            </div>
          </div>

          <div class="event-card" data-destructible>
            <div class="event-date">
              <span class="day">02</span>
              <span class="month">Nov</span>
            </div>
            <div class="event-details">
              <h3>Séance with the Departed</h3>
              <p>
                Our resident medium attempts contact with the seventeen spirits
                documented within these walls. Most sessions are uneventful.
                Some are not.
              </p>
              <span class="event-time">9:00 PM — 11:00 PM</span>
            </div>
            <div class="event-cta">
              <button class="event-button">Join</button>
            </div>
          </div>
        </div>

        <div class="events-image">
          <div class="events-image-item" data-destructible>
            <img src="/assets/images/about/seance.webp" alt="Séance at Via Mortis" />
            <div class="events-image-overlay"></div>
          </div>
          <div class="events-image-item" data-destructible>
            <img src="/assets/images/about/occult-calendar.webp" alt="Occult calendar" />
            <div class="events-image-overlay"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Louver 4 — After Events -->
  <LouverStrip
    image="/assets/images/parallax-strips/face-3.webp"
    slitHeights={[120, 90, 160, 110, 140]}
    gapHeights={[90, 100, 80, 95]}
    parallaxDirection="diagonal-right"
    className="louver-4"
  />

  <!-- Contact/Footer Section -->
  <section class="section contact-section" data-ghost-reveal>
    <div class="container ghost-real-content">
      <div class="contact-content">
        <div class="contact-info">
          <h2>Final Correspondence</h2>

          <div class="contact-details" data-destructible>
            <div class="detail-item">
              <span class="detail-label">Address</span>
              <span class="detail-value">2475 Glendower Ave., Los Angeles, CA</span
              >
            </div>
            <div class="detail-item">
              <span class="detail-label">Phone</span>
              <span class="detail-value">(213) 590-VIAM</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Hours</span>
              <span class="detail-value">Dusk till Dawn, Every Night</span>
            </div>
          </div>
        </div>

        <div class="warning-notice" data-destructible>
          <h4 class="warning-title">Warning</h4>
          <GlitchTransition trigger="hover" intensity="medium">
            <p>
              Via Mortis is not responsible for psychological trauma, existential
              dread, or permanent changes to your perception of reality. Enter at
              your own risk.
            </p>
          </GlitchTransition>
          <div class="destruction-cta">
            <button
              class="destruction-button"
              data-graveyard-trigger
              data-destruction-trigger
              data-destructible>Please take me</button
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Section headings — IM Fell English throughout */
  .tap-list h2,
  .our-story h2,
  .observations-section h2,
  .events-section h2,
  .contact-info h2 {
    font-family: "IM Fell English", serif;
    font-size: clamp(2rem, 6vw, 3rem);
    color: #DCE6E2;
    text-shadow: 0 0 20px rgba($cold-pale-fog, 0.1);
    margin-left: 0.5rem;
  }

  /* Hero Section */
  .hero {
    position: relative;
    background:
      radial-gradient(
        ellipse 80% 60% at 50% 42%,
        #1a2822 0%,
        #0e1614 50%,
        #070c0b 100%
      );
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .hero-title-wrapper {
    font-family: "IM Fell English", serif;
    font-size: clamp(4rem, 12vw, 10rem) !important;
  }

  .hero-title-wrapper h1 {
    font-family: "IM Fell English", serif;
    font-size: clamp(4rem, 12vw, 10rem);
    color: #98aeb8;
    text-shadow: 0 0 60px rgba(152, 174, 184, 0.08);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    margin-bottom: 0;
  }


  .hero-subtitle p {
    font-size: clamp(2rem, 5vw, 2.6rem);
    color: #4e5f6b;
    /* font-style: italic; */
    font-family: "IM Fell English", serif;
    letter-spacing: 0.05em;
    opacity: 1;
    /* animation: subtitle-fade 1.5s ease-out 2s forwards; */
    transition: all 1.8s ease-in-out;
  }

  .hero-subtitle:hover p {
    color: #3e2f44;
    opacity: 0.5;
    /* text-shadow: 0 0 30px rgba(62, 47, 68, 0.3); */
  }

  @keyframes subtitle-fade {
    to {
      opacity: 0.7;
    }
  }

  .hero-fog {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 65vh;
    background: linear-gradient(
      to top,
      #0e1614       0%,
      rgba(14, 22, 20, 0.98)  4%,
      rgba(14, 22, 20, 0.94) 10%,
      rgba(14, 22, 20, 0.86) 18%,
      rgba(14, 22, 20, 0.72) 28%,
      rgba(14, 22, 20, 0.53) 40%,
      rgba(14, 22, 20, 0.33) 54%,
      rgba(14, 22, 20, 0.16) 68%,
      rgba(14, 22, 20, 0.05) 82%,
      transparent           100%
    );
    z-index: 1;
    pointer-events: none;
  }

/* Attractions Grid */
  .attractions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    row-gap: 6rem;
    column-gap: 3rem;
    margin-top: 4rem;
    padding: 0 1rem;
    align-items: stretch;
  }

  /* Force full-height chain inside the grid. Astro scopes each component's
     styles to its own hash, so cross-component targeting requires :global(). */
  .attractions-grid :global(.post-card-link),
  .attractions-grid :global(.post-card),
  .attractions-grid :global(.displacement-wrapper) {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Our Story Section */
  .our-story {
    background: linear-gradient(135deg, #0f1417 0%, #1a2326 50%, #0f1417 100%);
    padding: 12rem 2rem;
    margin-top: 0;
  }

  .story-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    align-items: center;
  }

  .story-text h2 {
    margin-bottom: 3rem;
  }

  .story-paragraphs p {
    margin: 1.5rem 0 0 1rem;
    font-size: 1.1rem;
    line-height: 1.9;
    color: #e2ded6;
  }

  .story-image {
    position: relative;
    overflow: hidden;
  }

  .story-image img {
    display: block;
    width: 100%;
    height: 500px;
    object-fit: cover;
    filter: grayscale(60%) contrast(1.1);
    transition: transform 0.5s ease, filter 0.4s ease;
  }

  .story-image:hover img {
    transform: scale(1.03);
    filter: grayscale(0%) contrast(1.2);
  }

  .story-image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 40%,
      rgba(14, 22, 20, 0.6) 100%
    );
    pointer-events: none;
    transition: background 0.8s ease;
  }

  .story-image:hover .story-image-overlay {
    background: radial-gradient(
      ellipse at center,
      transparent 20%,
      rgba(14, 22, 20, 0.5) 55%,
      rgba(14, 22, 20, 0.85) 100%
    );
  }

  /* Events Section */
  .events-section {
    padding: 10rem 0;
  }

  .events-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    align-items: stretch;
    margin: 4rem 1rem;
  }

  .events-calendar {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    /* gap: 2rem; */
  }

  .events-image {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .events-image-item {
    position: relative;
    overflow: hidden;
    flex: 1;
    min-height: 0;
  }

  .events-image-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(60%) contrast(1.1);
    transition: transform 0.5s ease, filter 0.4s ease;
  }

  .events-image-item:hover img {
    transform: scale(1.03);
    filter: grayscale(0%) contrast(1.2);
  }

  .events-image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 40%,
      rgba(14, 22, 20, 0.6) 100%
    );
    pointer-events: none;
    transition: background 0.8s ease;
  }

  .events-image-item:hover .events-image-overlay {
    background: radial-gradient(
      ellipse at center,
      transparent 20%,
      rgba(14, 22, 20, 0.5) 55%,
      rgba(14, 22, 20, 0.85) 100%
    );
  }

  .event-card {
    background: rgba(15, 20, 23, 0.6);
    border: 1px solid rgba(70, 94, 99, 0.2);
    padding: 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    transition: border-color 0.3s ease;
  }

  .event-card:hover {
    border-color: rgba(62, 47, 68, 0.5);
  }

  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: linear-gradient(135deg, #1a2326, #2a3c42);
    padding: 1rem;
    min-width: 60px;
    flex-shrink: 0;
  }

  .event-date .day {
    font-size: 1.5rem;
    font-weight: 700;
    color: #98aeb8;
    font-family: "Fira Code", monospace;
  }

  .event-date .month {
    font-size: 0.875rem;
    color: #98aeb8;
    text-transform: uppercase;
    font-weight: 500;
  }

  .event-details {
    flex: 1;
  }

  .event-details h3 {
    color: #98aeb8;
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
  }

  .event-details p {
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    color: #dce6e2;
    opacity: 0.8;
    line-height: 1.6;
  }

  .event-time {
    font-size: 0.8rem;
    color: #4e5f6b;
    font-family: "Fira Code", monospace;
  }

  .event-button {
    width: 150px;
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
    white-space: nowrap;
    font-family: "Pathway Gothic One", sans-serif;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: inherit;
    transition: all 0.3s ease-in-out;
    flex-shrink: 0;
    background: linear-gradient(135deg, #2a2e30 0%, #353a3c 50%, #2a2e30 100%);
    border: 1px solid #465e63;
    color: #4e5f6b;
    text-shadow:
      0 1px 1px rgba(220, 230, 226, 0.08),
      0 -1px 1px rgba(0, 0, 0, 0.5);
    box-shadow:
      inset 0 1px 0 rgba(220, 230, 226, 0.05),
      inset 0 -1px 0 rgba(0, 0, 0, 0.4),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .event-button:hover {
    border-color: #3e2f44;
    color: #98aeb8;
    background: linear-gradient(135deg, #2a2e30 0%, #353a3c 50%, #2a2e30 100%);
    transform: none;
    box-shadow:
      inset 0 1px 0 rgba(220, 230, 226, 0.08),
      inset 0 -1px 0 rgba(0, 0, 0, 0.4),
      0 0 15px rgba(62, 47, 68, 0.2);
  }

  .event-button:active {
    transform: translateY(0);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      inset 0 -1px 0 rgba(0, 0, 0, 0.7),
      0 1px 2px rgba(0, 0, 0, 0.3);
  }

  /* Contact Section */
  .contact-section {
    background: linear-gradient(135deg, #0f1417 0%, #0e1614 50%, #0f1417 100%);
    padding: 10rem 2rem;
  }

  .contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-info h3 {
    margin-bottom: 2rem;
    color: #98aeb8;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-left: 1rem;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .detail-label {
    font-size: 1rem;
    color: #465e63;
    font-family: "Pathway Gothic One", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .detail-value {
    font-size: 1.1rem;
    color: #dce6e2;
    font-family: "Fira Code", monospace;
  }

  .warning-notice {
    background: rgba(15, 20, 23, 0.4);
    border: 1px solid rgba(78, 95, 107, 0.2);
    padding: 2rem;
  }

  .warning-title {
    font-family: "Pathway Gothic One", sans-serif;
    font-size: 1.5rem;
    color: #4e5f6b;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
  }

  .warning-notice p {
    font-size: 1rem;
    line-height: 1.6;
    color: #dce6e2;
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .destruction-cta {
    margin-top: 1.5rem;
  }

  .destruction-button {
    background: transparent;
    border: 1px solid rgba(90, 46, 46, 0.3);
    color: rgba(90, 46, 46, 0.6);
    font-family: "IM Fell English", serif;
    font-style: italic;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    padding: 0.75rem 1.5rem;
    cursor: inherit;
    transition: all 0.4s ease;
  }

  .destruction-button:hover {
    border-color: #5a2e2e;
    color: #5a2e2e;
    box-shadow: 0 0 30px rgba(90, 46, 46, 0.15);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-content {
      padding: 1rem;
    }

    .hero-title-wrapper {
      font-size: clamp(3rem, 4vw, 4rem) !important;
    }

