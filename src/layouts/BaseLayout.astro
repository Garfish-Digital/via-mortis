---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Via Mortis - Macabre Tourism & Haunted Attractions", image = "/og-image.jpg" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="description" content={description}>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  <!-- Subliminal flash preloads — must be in memory before first trigger -->
  <link rel="preload" as="image" href="/assets/images/subliminal-flash/flash-1.webp" />
  <link rel="preload" as="image" href="/assets/images/subliminal-flash/flash-2.webp" />

  <!-- SEO Meta Tags -->
  <title>{title}</title>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={image}>
  <meta property="og:image:type" content="image/jpeg">
  <meta property="og:image:width" content="3600">
  <meta property="og:image:height" content="1800">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={image}>
  
  <style>
    /* Critical CSS */
    body {
      margin: 0;
      padding: 0 1rem;
      background: #0E1614;
      color: #DCE6E2;
      overflow-x: hidden;
    }

  </style>
</head>

<body>
  <!-- Main Content -->
  <!-- <main id="main-content" class="ct-scanlines"> -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Subliminal Flash Overlay -->
  <!-- Inline styles are authoritative — CSS scoping must not interfere with opacity:0 -->
  <div
    id="subliminal-flash"
    class="subliminal-flash"
    aria-hidden="true"
    style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:99999;pointer-events:none;opacity:0;"
  >
    <div class="flash-frame" id="flash-frame-1" style="display:none;">
      <img src="/assets/images/subliminal-flash/flash-1.webp" alt="" />
    </div>
    <div class="flash-frame" id="flash-frame-2" style="display:none;">
      <img src="/assets/images/subliminal-flash/flash-2.webp" alt="" />
    </div>
  </div>

  <!-- Global Styles -->
  <style lang="scss">
    @import "../styles/global.scss";
  </style>

  <!-- Ghost Reveal System -->
  <script>
    import { initGhostReveal } from '../scripts/ghost-reveal.ts';
    // Module scripts are deferred — DOM is available when this runs
    initGhostReveal();
  </script>
 


  <!-- Scroll-driven choreography -->
  <script>
    import { initScrollController } from '../scripts/scroll-controller.ts';
    initScrollController();
  </script>

  <!-- Goetic sigil cursor system -->
  <script>
    import { initCursorController } from '../scripts/cursor-controller.ts';
    initCursorController();
  </script>

  <!-- Louver parallax -->
  <script>
    import { initLouverParallax } from '../scripts/louver-parallax.ts';
    initLouverParallax();
  </script>

  <!-- Audio -->
  <script>
    import { audioController } from '../scripts/audio-controller.ts';
    audioController.init();
  </script>

  <!-- Subliminal flash -->
  <script>
    import { initSubliminalFlash } from '../scripts/subliminal-flash.ts';
    initSubliminalFlash();
  </script>

  <!-- Canvas destruction sequence -->
  <script>
    import { initDestruction } from '../scripts/destruction-controller.ts';
    initDestruction();
  </script>

  <!-- Page transition glitch -->
  <script>
    document.addEventListener('astro:page-load', () => {
      document.body.classList.add('glitch-transition');
      setTimeout(() => {
        document.body.classList.remove('glitch-transition');
      }, 300);
    });
  </script>

  <!-- Scroll-state class: disables hover-triggered filter transitions while
       scrolling. Without this, the page passing under the cursor fires expensive
       feTurbulence + image filter transitions on cards, which stall render frames
       past 16ms and drop scroll velocity. CSS rules live in global.scss. -->
  <script>
    (() => {
      let scrollTimer: ReturnType<typeof setTimeout> | undefined;
      const body = document.body;
      window.addEventListener('scroll', () => {
        if (!body.classList.contains('is-scrolling')) {
          body.classList.add('is-scrolling');
        }
        if (scrollTimer !== undefined) clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => body.classList.remove('is-scrolling'), 150);
      }, { passive: true });
    })();
  </script>
</body>
</html>